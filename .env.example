# ----------------------------
# Runtime / locale
# ----------------------------
TZ=Asia/Shanghai
LANG=C.UTF-8
LC_ALL=C.UTF-8

# ----------------------------
# Gallery and API behavior
# ----------------------------
# Gallery root path for static files and scanning.
GALLERY_DIR=/data/gallery
# Static URL prefix for image access.
STATIC_PREFIX=/static
# Allowed image suffixes used during indexing/random pick.
ALLOWED_SUFFIXES=.jpg,.jpeg,.png,.gif,.webp
# Whether to recursively scan subdirectories under GALLERY_DIR.
RECURSIVE=true
# Write EXIF/XMP metadata only when rating count >= this value.
WRITE_META_MIN_COUNT=1
# Random pick policy: off|min|weighted
PICK_BIAS=min
# Bias strength when PICK_BIAS=weighted (larger -> stronger preference for low cnt).
PICK_BIAS_ALPHA=1.0

# ----------------------------
# Legacy SQLite app DB (existing service logic)
# ----------------------------
# Used by infra/db.py and infra/migrations.py.
DB_PATH=/data/db/picapi.sqlite

# ----------------------------
# Metadata backend selection (Phase 3)
# ----------------------------
# Try PostgreSQL metadata store when true; use SQLite directly when false.
USE_PG=true
# If PostgreSQL init fails:
# - false: fail-fast (recommended for production)
# - true: fallback to SQLite metadata store
ALLOW_SQLITE_FALLBACK=false
# PostgreSQL DSN for metadata store.
# Example with your local test settings:
# postgresql://postgres:123456@localhost:5432/postgres
PG_DSN=postgresql://postgres:123456@localhost:5432/postgres
# PostgreSQL connect timeout (seconds) for availability probe.
PG_CONNECT_TIMEOUT_SEC=3
# PostgreSQL connection pool bounds.
PG_POOL_MIN=1
PG_POOL_MAX=5

# SQLite file used by metadata store when USE_PG=false or fallback is enabled.
METADATA_SQLITE_PATH=/data/db/metadata.sqlite

# ----------------------------
# Phase 4: SQLite -> PostgreSQL migration
# ----------------------------
# Run migration automatically at startup when backend is PostgreSQL.
MIGRATION_AUTO_RUN=true
# Dry-run only prints stats/progress; does not write to PostgreSQL.
MIGRATION_DRY_RUN=false
# Batch size for migration loop.
MIGRATION_BATCH_SIZE=1000
# Limit migrated rows (0 means no limit).
MIGRATION_LIMIT=0
# JSON checkpoint path used for resume.
MIGRATION_CHECKPOINT_PATH=/data/db/metadata_migration_checkpoint.json

# ----------------------------
# Phase 5: FAISS retrieval (optional)
# ----------------------------
# Enable FAISS-first search pipeline for /search (fallback to FTS/LIKE on failure).
ENABLE_FAISS_SEARCH=false
# FAISS index file path.
FAISS_INDEX_PATH=/data/faiss/images.faiss
# FAISS id-map path (index position -> metadata id/external_id).
FAISS_ID_MAP_PATH=/data/faiss/id_map.json
# CLIP model used for query image encoding.
CLIP_MODEL_ID=AI-ModelScope/chinese-clip-vit-large-patch14
