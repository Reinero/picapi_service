# ----------------------------
# 运行时 / 区域设置
# ----------------------------
TZ=Asia/Shanghai
LANG=C.UTF-8
LC_ALL=C.UTF-8

# ----------------------------
# 图库和 API 行为配置
# ----------------------------
# 静态文件和扫描的图库根路径。
GALLERY_DIR=/data/gallery
# 图片访问的静态 URL 前缀。
STATIC_PREFIX=/static
# 索引/随机抽取时允许的图片后缀名。
ALLOWED_SUFFIXES=.jpg,.jpeg,.png,.gif,.webp
# 是否递归扫描 GALLERY_DIR 下的子目录。
RECURSIVE=true
# 仅当评分次数 >= 此值时才写入 EXIF/XMP 元数据。
WRITE_META_MIN_COUNT=1
# 随机抽取策略：off（关闭）| min（最少评分优先）| weighted（加权）
PICK_BIAS=min
# 当 PICK_BIAS=weighted 时的偏置强度（值越大，越偏好低评分次数的图片）。
PICK_BIAS_ALPHA=1.0

# ----------------------------
# 传统 SQLite 应用数据库（现有服务逻辑）
# ----------------------------
# 由 infra/db.py 和 infra/migrations.py 使用。
DB_PATH=/data/db/picapi.sqlite

# ----------------------------
# 元数据后端选择（第三阶段）
# ----------------------------
# 为 true 时尝试使用 PostgreSQL 元数据存储；为 false 时直接使用 SQLite。
USE_PG=true
# PostgreSQL 初始化失败时的处理策略：
# - false: 快速失败（生产环境推荐）
# - true: 回退到 SQLite 元数据存储
ALLOW_SQLITE_FALLBACK=false
# 元数据存储的 PostgreSQL DSN。
# 使用本地测试设置的示例：
# postgresql://postgres:123456@localhost:5432/postgres
PG_DSN=postgresql://postgres:123456@localhost:5432/postgres
# PostgreSQL 可用性探测的连接超时时间（秒）。
PG_CONNECT_TIMEOUT_SEC=3
# PostgreSQL 连接池的最小和最大连接数。
PG_POOL_MIN=1
PG_POOL_MAX=5

# 当 USE_PG=false 或启用回退时，元数据存储使用的 SQLite 文件路径。
METADATA_SQLITE_PATH=/data/db/metadata.sqlite

# ----------------------------
# 第四阶段：SQLite 到 PostgreSQL 迁移
# ----------------------------
# 当后端为 PostgreSQL 时，在启动时自动运行迁移。
MIGRATION_AUTO_RUN=true
# 仅干跑模式：只打印统计信息和进度，不写入 PostgreSQL。
MIGRATION_DRY_RUN=false
# 迁移循环的批次大小。
MIGRATION_BATCH_SIZE=1000
# 限制迁移的行数（0 表示无限制）。
MIGRATION_LIMIT=0
# 用于断点续传的 JSON 检查点文件路径。
MIGRATION_CHECKPOINT_PATH=/data/db/metadata_migration_checkpoint.json